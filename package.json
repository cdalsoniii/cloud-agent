{
  "name": "cloud-agent-handoff",
  "version": "1.0.0",
  "description": "Cloud agent handoff via OpenCode skills and Baseten chain sandbox communication",
  "type": "module",
  "scripts": {
    "deploy-schema": "npx tsx src/deploy-schema.ts",
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "node --test dist/**/*.test.js",
    "test:integration": "npx tsx test/integration.test.ts",
    "lint": "eslint src/**/*.ts",
    "handoff": "npx tsx src/cloud-agent-handoff.ts",
    "chain-sandbox": "npx tsx src/baseten-chain-sandbox.ts",
    "orchestrate": "npx tsx src/orchestrator.ts",
    "pr-sandbox": "npx tsx src/pr-sandbox-orchestrator.ts",
    "health": "npx tsx src/health-check.ts",
    "mastra:daytona": "npx tsx src/mastra/index.ts",
    "mastra:verify": "npx tsx src/mastra/tools/verify-rules.ts",
    "mastra:mcp": "bash scripts/run-mastra-mcp.sh",
    "mastra:mcp:sse": "MCP_TRANSPORT=sse bash scripts/run-mastra-mcp.sh",
    "baseten-proxy": "node baseten-proxy.js",
    "gateway": "node gateway.js",
    "verify-data": "npx tsx src/verify-data-loading.ts",
    "sync:opencode": "npx tsx src/sync-opencode-to-surreal.ts",
    "api:sessions": "npx tsx src/session-api.ts",
    "validation:test": "npx tsx test-validation.ts",
    "validation:run": "npx tsx src/validation/run-validation.ts"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.5.20",
    "@daytona/sdk": "^0.199.0",
    "@mastra/core": "^0.1.26",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "dotenv": "^16.4.5",
    "node-fetch": "^3.3.2",
    "surqlize": "^0.1.0",
    "surrealdb": "^2.0.4",
    "surrealdb-orm": "^1.8.9",
    "yaml": "^2.9.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "eslint": "^8.57.0",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
